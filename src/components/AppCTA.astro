---
export interface Props {
  variant?: 'banner' | 'inline';
}

const { variant = 'inline' } = Astro.props;
const iOSUrl = 'https://apps.apple.com/us/app/bpt-best-poker-tracker/id6778269945';
const androidUrl = 'https://bpt.lanzn.com/iZfRr3tgy9sf';
---

{
  variant === 'banner' ? (
    <section class="relative bg-gradient-to-r from-poker-felt via-poker-green to-poker-green-light overflow-hidden">
      <!-- Decorative suits -->
      <span class="suit-spade suit-corner-tl absolute text-6xl opacity-10 select-none" aria-hidden="true"></span>
      <span class="suit-heart suit-corner-tr absolute text-6xl opacity-10 select-none" aria-hidden="true"></span>

      <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-12 sm:py-16 relative z-10">
        <div class="flex flex-col lg:flex-row items-center justify-between gap-8">
          <div class="text-center lg:text-left max-w-lg">
            <h2 class="text-2xl sm:text-3xl font-bold text-white mb-3">
              Ready to Crush the Tables?
            </h2>
            <p class="text-green-200/80 text-sm sm:text-base leading-relaxed">
              Download <strong>BPT - Best Poker Tracker</strong> &mdash; the ultimate 
              <strong>free poker tracker</strong> with session tracking, bankroll management, 
              and detailed hand logging. Available on iOS and Android.
            </p>
          </div>
          <div class="flex flex-col sm:flex-row gap-3">
            <a
              href={iOSUrl}
              class="cta-button text-sm sm:text-base"
              target="_blank"
              rel="noopener noreferrer"
            >
              <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M18.71 19.5c-.83 1.24-1.71 2.45-3.05 2.47-1.34.03-1.77-.79-3.29-.79-1.53 0-2 .77-3.27.82-1.31.05-2.3-1.32-3.14-2.53C4.25 17 2.94 12.45 4.7 9.39c.87-1.52 2.43-2.48 4.12-2.51 1.28-.02 2.5.87 3.29.87.78 0 2.26-1.07 3.8-.91.65.03 2.47.26 3.64 1.98-.09.06-2.17 1.28-2.15 3.81.03 3.02 2.65 4.03 2.68 4.04-.03.07-.42 1.44-1.38 2.83M13 3.5c.73-.83 1.94-1.46 2.94-1.5.13 1.17-.34 2.35-1.04 3.19-.69.85-1.83 1.51-2.95 1.42-.15-1.15.41-2.35 1.05-3.11z"/></svg>
              <span>App Store</span>
            </a>
            <a
              href={androidUrl}
              class="cta-button-secondary text-sm sm:text-base"
              target="_blank"
              rel="noopener noreferrer"
            >
              <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M6 18c0 .55.45 1 1 1h1v3.5a1.5 1.5 0 003 0V19h2v3.5a1.5 1.5 0 003 0V19h1c.55 0 1-.45 1-1V8H6v10zM3.5 8C2.67 8 2 8.67 2 9.5v7c0 .83.67 1.5 1.5 1.5S5 17.33 5 16.5v-7C5 8.67 4.33 8 3.5 8zm17 0c-.83 0-1.5.67-1.5 1.5v7c0 .83.67 1.5 1.5 1.5s1.5-.67 1.5-1.5v-7c0-.83-.67-1.5-1.5-1.5zm-4.97-5.84l1.3-1.3c.2-.2.2-.51 0-.71-.2-.2-.51-.2-.71 0l-1.48 1.48A5.96 5.96 0 0012 1c-.96 0-1.86.23-2.66.63L7.85.15c-.2-.2-.51-.2-.71 0-.2.2-.2.51 0 .71l1.31 1.31A5.983 5.983 0 006 7h12c0-1.99-.97-3.75-2.47-4.84zM10 5H9V4h1v1zm5 0h-1V4h1v1z"/></svg>
              <span>Android</span>
            </a>
          </div>
        </div>
      </div>
    </section>
  ) : (
    <div class="my-8 p-6 bg-gradient-to-r from-[#111a11] to-[#0d1510] rounded-xl border border-poker-green/30 text-center">
      <p class="text-gray-300 mb-3 font-medium">
        Enjoy this article? Get the <strong>BPT App</strong> &mdash; the best 
        <strong>poker tracker</strong> for session logging and bankroll tracking.
      </p>
      <div class="flex flex-col sm:flex-row items-center justify-center gap-3">
        <a
          href={iOSUrl}
          class="cta-button text-sm"
          target="_blank"
          rel="noopener noreferrer"
        >
          <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M18.71 19.5c-.83 1.24-1.71 2.45-3.05 2.47-1.34.03-1.77-.79-3.29-.79-1.53 0-2 .77-3.27.82-1.31.05-2.3-1.32-3.14-2.53C4.25 17 2.94 12.45 4.7 9.39c.87-1.52 2.43-2.48 4.12-2.51 1.28-.02 2.5.87 3.29.87.78 0 2.26-1.07 3.8-.91.65.03 2.47.26 3.64 1.98-.09.06-2.17 1.28-2.15 3.81.03 3.02 2.65 4.03 2.68 4.04-.03.07-.42 1.44-1.38 2.83M13 3.5c.73-.83 1.94-1.46 2.94-1.5.13 1.17-.34 2.35-1.04 3.19-.69.85-1.83 1.51-2.95 1.42-.15-1.15.41-2.35 1.05-3.11z"/></svg>
          <span>App Store</span>
        </a>
        <a
          href={androidUrl}
          class="cta-button-secondary text-sm"
          target="_blank"
          rel="noopener noreferrer"
        >
          <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M6 18c0 .55.45 1 1 1h1v3.5a1.5 1.5 0 003 0V19h2v3.5a1.5 1.5 0 003 0V19h1c.55 0 1-.45 1-1V8H6v10zM3.5 8C2.67 8 2 8.67 2 9.5v7c0 .83.67 1.5 1.5 1.5S5 17.33 5 16.5v-7C5 8.67 4.33 8 3.5 8zm17 0c-.83 0-1.5.67-1.5 1.5v7c0 .83.67 1.5 1.5 1.5s1.5-.67 1.5-1.5v-7c0-.83-.67-1.5-1.5-1.5zm-4.97-5.84l1.3-1.3c.2-.2.2-.51 0-.71-.2-.2-.51-.2-.71 0l-1.48 1.48A5.96 5.96 0 0012 1c-.96 0-1.86.23-2.66.63L7.85.15c-.2-.2-.51-.2-.71 0-.2.2-.2.51 0 .71l1.31 1.31A5.983 5.983 0 006 7h12c0-1.99-.97-3.75-2.47-4.84zM10 5H9V4h1v1zm5 0h-1V4h1v1z"/></svg>
          <span>Android</span>
        </a>
      </div>
      <p class="text-xs text-gray-500 mt-2">Android password: BPTT</p>
    </div>
  )
}

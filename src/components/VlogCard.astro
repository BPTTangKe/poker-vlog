---
import AppCTA from './AppCTA.astro';
import Breadcrumb from './Breadcrumb.astro';
import type { CollectionEntry } from 'astro:content';

export interface Props {
  vlog: CollectionEntry<'vlog'>;
}

const { vlog } = Astro.props;
const { title, date, tags } = vlog.data;
const slug = vlog.id.replace(/\.md$/, '');

export function formatDate(d: Date): string {
  const year = d.getFullYear();
  const month = String(d.getMonth() + 1).padStart(2, '0');
  const day = String(d.getDate()).padStart(2, '0');
  return `${year}-${month}-${day}`;
}

// Randomly pick a suit for decoration
const suits = ['suit-spade', 'suit-heart', 'suit-diamond', 'suit-club'];
const randomSuit = suits[Math.floor(Math.random() * suits.length)];
---

<article class={`vlog-card ${randomSuit} suit-corner-tr relative overflow-hidden`}>
  <header>
    <div class="flex items-center gap-3 text-xs text-gray-500 mb-3">
      <time datetime={date.toISOString()}>{formatDate(date)}</time>
      {tags.length > 0 && (
        <span aria-hidden="true" class="text-poker-green/50">|</span>
      )}
      <div class="flex flex-wrap gap-1.5">
        {tags.map(tag => (
          <span class="tag-badge">{tag}</span>
        ))}
      </div>
    </div>

    <h2 class="text-xl sm:text-2xl font-bold text-white mb-2 leading-tight relative z-10">
      <a href={`${import.meta.env.BASE_URL}vlog/${slug}`} class="hover:text-poker-gold transition-colors">
        {title}
      </a>
    </h2>
  </header>

  <p class="text-gray-400 text-sm sm:text-base leading-relaxed mb-4 relative z-10">
    {vlog.data.excerpt}
  </p>

  <div class="flex items-center justify-between relative z-10">
    <a
      href={`${import.meta.env.BASE_URL}vlog/${slug}`}
      class="inline-flex items-center gap-1 text-sm font-medium text-poker-gold hover:text-amber-300 transition-colors"
    >
      Read More
      <span aria-hidden="true">&rarr;</span>
    </a>
  </div>
</article>

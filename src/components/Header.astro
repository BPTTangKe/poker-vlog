---
const navItems = [
  { href: '/', label: '首页' },
  { href: '/archive', label: '归档' },
  { href: '/about', label: '关于' },
];

const base = import.meta.env.BASE_URL || '/';
const iOSUrl = 'https://apps.apple.com/us/app/bpt-best-poker-tracker/id6778269945';
const androidUrl = 'https://bpt.lanzn.com/iZfRr3tgy9sf';
---

<header class="sticky top-0 z-50 nav-glass">
  <nav class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between h-16">
      <!-- Logo -->
      <a href={base} class="flex items-center gap-2 group" aria-label="首页">
        <span class="text-2xl">♠</span>
        <span class="text-xl font-bold text-white group-hover:text-poker-gold transition-colors">
          Poker Vlog
        </span>
      </a>

      <!-- Desktop nav -->
      <div class="hidden sm:flex items-center gap-1">
        {navItems.map(item => (
          <a
            href={item.href === '/' ? base : `${base}${item.href.replace('/', '')}`}
            class="px-3 py-2 text-sm font-medium text-gray-400 hover:text-poker-gold transition-colors rounded-lg hover:bg-white/5"
          >
            {item.label}
          </a>
        ))}

        <!-- Download App dropdown trigger -->
        <div class="relative group/download">
          <button class="px-3 py-2 text-sm font-medium text-poker-gold hover:text-amber-300 transition-colors rounded-lg hover:bg-poker-gold/10 flex items-center gap-1">
            Download App
            <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
          </button>
          <div class="absolute right-0 mt-1 w-56 bg-[#111a11] border border-poker-green/30 rounded-lg shadow-xl opacity-0 invisible group-hover/download:opacity-100 group-hover/download:visible transition-all duration-200 z-50">
            <a href={iOSUrl} target="_blank" rel="noopener noreferrer" class="flex items-center gap-3 px-4 py-3 text-sm text-gray-300 hover:bg-white/5 hover:text-poker-gold rounded-t-lg transition-colors">
              <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M18.71 19.5c-.83 1.24-1.71 2.45-3.05 2.47-1.34.03-1.77-.79-3.29-.79-1.53 0-2 .77-3.27.82-1.31.05-2.3-1.32-3.14-2.53C4.25 17 2.94 12.45 4.7 9.39c.87-1.52 2.43-2.48 4.12-2.51 1.28-.02 2.5.87 3.29.87.78 0 2.26-1.07 3.8-.91.65.03 2.47.26 3.64 1.98-.09.06-2.17 1.28-2.15 3.81.03 3.02 2.65 4.03 2.68 4.04-.03.07-.42 1.44-1.38 2.83M13 3.5c.73-.83 1.94-1.46 2.94-1.5.13 1.17-.34 2.35-1.04 3.19-.69.85-1.83 1.51-2.95 1.42-.15-1.15.41-2.35 1.05-3.11z"/></svg>
              App Store (iOS)
            </a>
            <a href={androidUrl} target="_blank" rel="noopener noreferrer" class="flex items-center gap-3 px-4 py-3 text-sm text-gray-300 hover:bg-white/5 hover:text-poker-gold rounded-b-lg transition-colors">
              <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M6 18c0 .55.45 1 1 1h1v3.5a1.5 1.5 0 003 0V19h2v3.5a1.5 1.5 0 003 0V19h1c.55 0 1-.45 1-1V8H6v10zM3.5 8C2.67 8 2 8.67 2 9.5v7c0 .83.67 1.5 1.5 1.5S5 17.33 5 16.5v-7C5 8.67 4.33 8 3.5 8zm17 0c-.83 0-1.5.67-1.5 1.5v7c0 .83.67 1.5 1.5 1.5s1.5-.67 1.5-1.5v-7c0-.83-.67-1.5-1.5-1.5zm-4.97-5.84l1.3-1.3c.2-.2.2-.51 0-.71-.2-.2-.51-.2-.71 0l-1.48 1.48A5.96 5.96 0 0012 1c-.96 0-1.86.23-2.66.63L7.85.15c-.2-.2-.51-.2-.71 0-.2.2-.2.51 0 .71l1.31 1.31A5.983 5.983 0 006 7h12c0-1.99-.97-3.75-2.47-4.84zM10 5H9V4h1v1zm5 0h-1V4h1v1z"/></svg>
              Android (密码: BPTT)
            </a>
          </div>
        </div>

        <!-- Theme toggle -->
        <button
          id="themeToggle"
          class="p-2 rounded-lg text-gray-400 hover:text-poker-gold hover:bg-white/5 transition-colors"
          aria-label="切换亮色/暗色模式"
          title="切换亮色/暗色模式"
        >
          <span class="dark:hidden text-lg" aria-hidden="true">🌙</span>
          <span class="hidden dark:inline text-lg" aria-hidden="true">☀️</span>
        </button>
      </div>

      <!-- Mobile menu button -->
      <button
        id="mobileMenuBtn"
        class="sm:hidden p-2 rounded-lg text-gray-400 hover:text-poker-gold hover:bg-white/5 transition-colors"
        aria-label="菜单"
      >
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/>
        </svg>
      </button>
    </div>

    <!-- Mobile nav -->
    <div id="mobileNav" class="hidden sm:hidden pb-4 space-y-1">
      {navItems.map(item => (
        <a
          href={item.href === '/' ? base : `${base}${item.href.replace('/', '')}`}
          class="block px-3 py-2 text-sm font-medium text-gray-400 hover:text-poker-gold rounded-lg"
        >
          {item.label}
        </a>
      ))}
      <div class="border-t border-poker-green/20 my-2 pt-2">
        <a href={iOSUrl} target="_blank" rel="noopener noreferrer" class="block px-3 py-2 text-sm font-medium text-poker-gold">Download App (iOS)</a>
        <a href={androidUrl} target="_blank" rel="noopener noreferrer" class="block px-3 py-2 text-sm font-medium text-poker-gold">Download App (Android)</a>
      </div>
    </div>
  </nav>
</header>

<script>
  const toggle = document.getElementById('themeToggle')!;
  const mobileBtn = document.getElementById('mobileMenuBtn')!;
  const mobileNav = document.getElementById('mobileNav')!;

  toggle.addEventListener('click', () => {
    const html = document.documentElement;
    if (html.classList.contains('dark')) {
      html.classList.remove('dark');
      document.body.classList.add('light');
      localStorage.setItem('theme', 'light');
    } else {
      html.classList.add('dark');
      document.body.classList.remove('light');
      localStorage.setItem('theme', 'dark');
    }
  });

  mobileBtn.addEventListener('click', () => {
    mobileNav.classList.toggle('hidden');
  });
</script>

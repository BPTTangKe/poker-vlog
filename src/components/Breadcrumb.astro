---
export interface Props {
  items: Array<{ label: string; href?: string }>;
}

const { items } = Astro.props;
const base = import.meta.env.BASE_URL || '/';
---

<nav aria-label="面包屑导航" class="mb-6">
  <ol class="flex items-center gap-1.5 text-sm text-gray-500">
    <li>
      <a href={base} class="hover:text-poker-gold transition-colors">Home</a>
    </li>
    {items.map((item, i) => (
      <li class="flex items-center gap-1.5">
        <span aria-hidden="true">/</span>
        {item.href ? (
          <a href={item.href} class="hover:text-poker-gold transition-colors">{item.label}</a>
        ) : (
          <span class="text-gray-300 font-medium truncate max-w-[200px] sm:max-w-xs">{item.label}</span>
        )}
      </li>
    ))}
  </ol>
</nav>

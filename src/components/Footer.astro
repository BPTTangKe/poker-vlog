---
const base = import.meta.env.BASE_URL || '/';
---

<footer class="bg-gray-100 dark:bg-gray-900 border-t border-gray-200 dark:border-gray-800 mt-auto">
  <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
      <div>
        <h3 class="text-lg font-heading font-bold text-gray-900 dark:text-white mb-3">
          ♠️ Poker Vlog
        </h3>
        <p class="text-sm text-gray-600 dark:text-gray-400">
          每日德州扑克 vlog，分享手牌分析、策略思考和牌桌故事。
        </p>
      </div>
      <div>
        <h4 class="text-sm font-semibold text-gray-900 dark:text-white uppercase tracking-wider mb-3">导航</h4>
        <ul class="space-y-2">
          <li><a href={base} class="text-sm text-gray-600 dark:text-gray-400 hover:text-poker-gold transition-colors">首页</a></li>
          <li><a href={`${base}archive`} class="text-sm text-gray-600 dark:text-gray-400 hover:text-poker-gold transition-colors">归档</a></li>
          <li><a href={`${base}about`} class="text-sm text-gray-600 dark:text-gray-400 hover:text-poker-gold transition-colors">关于</a></li>
          <li><a href={`${base}rss.xml`} class="text-sm text-gray-600 dark:text-gray-400 hover:text-poker-gold transition-colors">RSS Feed</a></li>
        </ul>
      </div>
      <div>
        <h4 class="text-sm font-semibold text-gray-900 dark:text-white uppercase tracking-wider mb-3">关注</h4>
        <ul class="space-y-2">
          <li><a href="https://x.com" target="_blank" rel="noopener noreferrer" class="text-sm text-gray-600 dark:text-gray-400 hover:text-poker-gold transition-colors">X (Twitter)</a></li>
          <li><a href="https://reddit.com" target="_blank" rel="noopener noreferrer" class="text-sm text-gray-600 dark:text-gray-400 hover:text-poker-gold transition-colors">Reddit</a></li>
        </ul>
      </div>
    </div>
    <div class="mt-8 pt-8 border-t border-gray-200 dark:border-gray-800">
      <p class="text-center text-xs text-gray-500 dark:text-gray-500">
        &copy; {new Date().getFullYear()} Poker Vlog. Built with Astro. All rights reserved.
      </p>
    </div>
  </div>
</footer>

---
const base = import.meta.env.BASE_URL || '/';
---

<footer class="bg-[#060a06] border-t border-poker-green/20 mt-auto">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <div class="grid grid-cols-1 md:grid-cols-4 gap-8">
      <!-- Brand -->
      <div class="md:col-span-1">
        <div class="flex items-center gap-2 mb-3">
          <span class="text-2xl">♠</span>
          <span class="text-lg font-bold text-white">Poker Vlog</span>
        </div>
        <p class="text-sm text-gray-500 leading-relaxed">
          Professional poker strategy, hand analysis, and daily vlogs for serious players.
        </p>
      </div>

      <!-- Navigation -->
      <div>
        <h4 class="text-xs font-semibold text-poker-gold uppercase tracking-widest mb-4">导航</h4>
        <ul class="space-y-2.5">
          <li><a href={base} class="text-sm text-gray-400 hover:text-poker-gold transition-colors">首页</a></li>
          <li><a href={`${base}archive`} class="text-sm text-gray-400 hover:text-poker-gold transition-colors">归档</a></li>
          <li><a href={`${base}about`} class="text-sm text-gray-400 hover:text-poker-gold transition-colors">关于</a></li>
          <li><a href={`${base}rss.xml`} class="text-sm text-gray-400 hover:text-poker-gold transition-colors">RSS Feed</a></li>
        </ul>
      </div>

      <!-- App Download -->
      <div>
        <h4 class="text-xs font-semibold text-poker-gold uppercase tracking-widest mb-4">Download App</h4>
        <ul class="space-y-2.5">
          <li><a href="https://apps.apple.com/us/app/bpt-best-poker-tracker/id6778269945" target="_blank" rel="noopener noreferrer" class="text-sm text-gray-400 hover:text-poker-gold transition-colors">App Store (iOS)</a></li>
          <li><a href="https://bpt.lanzn.com/iZfRr3tgy9sf" target="_blank" rel="noopener noreferrer" class="text-sm text-gray-400 hover:text-poker-gold transition-colors">Android APK (密码: BPTT)</a></li>
        </ul>
      </div>

      <!-- Social -->
      <div>
        <h4 class="text-xs font-semibold text-poker-gold uppercase tracking-widest mb-4">关注我们</h4>
        <div class="flex items-center gap-4">
          <a href="https://x.com" target="_blank" rel="noopener noreferrer" class="text-gray-400 hover:text-poker-gold transition-colors" aria-label="X (Twitter)">
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
          </a>
          <a href="https://reddit.com" target="_blank" rel="noopener noreferrer" class="text-gray-400 hover:text-poker-gold transition-colors" aria-label="Reddit">
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2a10 10 0 100 20 10 10 0 000-20zm4.4 10.9a1.4 1.4 0 01-1.4 1.4c-.39 0-.74-.16-1-.41-.98.7-2.34 1.16-3.85 1.21l.72-3.39 2.38.5a1.4 1.4 0 112.15.69zm-8.8 0a1.4 1.4 0 012.15-.69l2.38-.5.72 3.39c-1.51-.05-2.87-.51-3.85-1.21a1.39 1.39 0 11-1.4 1.01zm3.5 3.6c.76-.76 2-.82 2-.82s1.24.06 2 .82c.1.1.1.26 0 .36-.1.1-.26.1-.36 0-.56-.56-1.64-.68-1.64-.68s-1.08.12-1.64.68c-.1.1-.26.1-.36 0a.26.26 0 010-.36z"/></svg>
          </a>
          <a href="https://github.com" target="_blank" rel="noopener noreferrer" class="text-gray-400 hover:text-poker-gold transition-colors" aria-label="GitHub">
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z"/></svg>
          </a>
        </div>
      </div>
    </div>

    <!-- SEO Keywords -->
    <div class="mt-10 pt-8 border-t border-poker-green/20">
      <p class="seo-keywords text-center">
        Poker Vlog provides in-depth strategy for serious players. Use our
        <strong>free poker tracker</strong> to analyze every session. Our 
        <strong>poker tracker</strong> includes a <strong>poker session tracker</strong>,
        <strong>poker bankroll tracker</strong>, and an intuitive 
        <strong>poker logger</strong> to help you improve your win rate.
        Download the best poker tracking app today.
      </p>
    </div>

    <!-- Copyright -->
    <div class="mt-6 pt-6 border-t border-poker-green/10">
      <p class="text-center text-xs text-gray-600">
        &copy; {new Date().getFullYear()} Poker Vlog. Built with Astro. All rights reserved.
      </p>
    </div>
  </div>
</footer>

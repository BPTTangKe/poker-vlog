---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';

export interface Props {
  title: string;
  description: string;
  image?: string;
  canonicalURL?: string;
  type?: string;
  publishedTime?: string;
  tags?: string[];
}

const {
  title,
  description,
  image = '/og-default.png',
  canonicalURL,
  type = 'website',
  publishedTime,
  tags = [],
} = Astro.props;

const siteURL = Astro.site?.origin ?? '';
const pageURL = canonicalURL ?? Astro.url.href;
const fullTitle = `${title} | Free Poker Tracker & Strategy`;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    <meta name="keywords" content="free poker tracker, poker tracker, poker session tracker, poker bankroll tracker, poker logger, poker strategy, texas holdem" />
    <link rel="canonical" href={pageURL} />
    <meta property="og:type" content={type === 'article' ? 'article' : 'website'} />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={pageURL} />
    <meta property="og:site_name" content="Poker Vlog" />
    {image && <meta property="og:image" content={new URL(image, siteURL).href} />}
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />
    {image && <meta name="twitter:image" content={new URL(image, siteURL).href} />}
    <link rel="alternate" type="application/rss+xml" title="Poker Vlog RSS" href={`${Astro.site}${import.meta.env.BASE_URL}rss.xml`} />
    <link rel="icon" type="image/svg+xml" href={`${import.meta.env.BASE_URL}favicon.svg`} />
  </head>
  <body>
    <Header />
    <div class="page-content">
      <slot />
    </div>
    <Footer />
    {
      publishedTime && type === 'article' && (
        <script type="application/ld+json" set:html={JSON.stringify({
          '@context': 'https://schema.org',
          '@type': 'Article',
          headline: title,
          description: description,
          image: image ? new URL(image, siteURL).href : undefined,
          datePublished: publishedTime,
          dateModified: publishedTime,
          author: { '@type': 'Person', name: 'Poker Vlogger' },
          publisher: { '@type': 'Organization', name: 'Poker Vlog' },
          url: pageURL,
          ...(tags.length > 0 && { keywords: tags.join(', ') }),
        })} />
      )
    }
  </body>
</html>

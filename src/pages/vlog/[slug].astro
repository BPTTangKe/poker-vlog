---
import BaseLayout from '../../layouts/BaseLayout.astro';
import AppCTA from '../../components/AppCTA.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const vlogs = await getCollection('vlog');
  return vlogs.map(vlog => ({
    params: { slug: vlog.id.replace(/\.md$/, '') },
    props: { vlog },
  }));
}

const { vlog } = Astro.props;
const { title, date, excerpt, tags, seo_description, image } = vlog.data;
const { Content } = await vlog.render();
const slug = vlog.id.replace(/\.md$/, '');

export function formatDate(d: Date): string {
  const year = d.getFullYear();
  const month = String(d.getMonth() + 1).padStart(2, '0');
  const day = String(d.getDate()).padStart(2, '0');
  return `${year}-${month}-${day}`;
}
---

<BaseLayout
  title={title}
  description={seo_description || excerpt}
  image={image || undefined}
  type="article"
  publishedTime={date.toISOString()}
  tags={tags}
  canonicalURL={new URL(`${import.meta.env.BASE_URL}vlog/${slug}`, Astro.site).href}
>
  <article class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-10">
    <Breadcrumb
      items={[{ label: title }]}
    />

    <header class="mb-8">
      <h1 class="text-3xl sm:text-4xl font-extrabold text-white mb-4 leading-tight">
        {title}
      </h1>

      <div class="flex flex-wrap items-center gap-3 text-sm text-gray-500 mb-4">
        <time datetime={date.toISOString()}>{formatDate(date)}</time>
        {tags.length > 0 && (
          <>
            <span aria-hidden="true" class="text-poker-green/50">|</span>
            <div class="flex flex-wrap gap-1.5">
              {tags.map(tag => (
                <span class="tag-badge">{tag}</span>
              ))}
            </div>
          </>
        )}
      </div>

      {image && (
        <img
          src={image}
          alt={title}
          class="w-full rounded-xl shadow-md mb-6"
          loading="lazy"
          decoding="async"
        />
      )}
    </header>

    <div class="prose-content">
      <Content />
    </div>

    <AppCTA />

    <nav class="mt-10 pt-6 border-t border-poker-green/20">
      <a
        href={import.meta.env.BASE_URL || '/'}
        class="text-sm text-poker-gold hover:text-amber-300 transition-colors inline-flex items-center gap-1"
      >
        <span aria-hidden="true">&larr;</span> Back to Home
      </a>
    </nav>
  </article>
</BaseLayout>

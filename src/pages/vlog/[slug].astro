---
import BaseLayout from '../../layouts/BaseLayout.astro';
import AppCTA from '../../components/AppCTA.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import VlogCard from '../../components/VlogCard.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const vlogs = await getCollection('vlog');
  return vlogs.map(vlog => ({
    params: { slug: vlog.id.replace(/\.md$/, '') },
    props: { vlog },
  }));
}

const { vlog } = Astro.props;
const { title, date, excerpt, tags, seo_description, image } = vlog.data;
const { Content } = await vlog.render();
const slug = vlog.id.replace(/\.md$/, '');

function formatDate(d: Date): string {
  const months = ['Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec'];
  return `${months[d.getMonth()]} ${d.getDate()}, ${d.getFullYear()}`;
}

const readTime = Math.max(1, Math.round(excerpt.length / 1200));

/* Get related vlogs (2 most recent excluding current) */
const allVlogs = await getCollection('vlog');
allVlogs.sort((a, b) => b.data.date.getTime() - a.data.date.getTime());
const relatedVlogs = allVlogs.filter(v => v.id !== vlog.id).slice(0, 2);
---

<BaseLayout
  title={title}
  description={seo_description || excerpt}
  image={image || `${import.meta.env.BASE_URL}images/${slug}.svg`}
  type="article"
  publishedTime={date.toISOString()}
  tags={tags}
  canonicalURL={new URL(`${import.meta.env.BASE_URL}vlog/${slug}`, Astro.site).href}
>
  <div class="main-content">
    <Breadcrumb items={[{ label: title }]} />

    <article>
      <!-- Cover Image -->
      <img
        src={`${import.meta.env.BASE_URL}images/${slug}.svg`}
        alt={title}
        class="article-cover"
        width="720"
        height="400"
      />

      <header class="article-header">
        <div class="article-meta">
          <time datetime={date.toISOString()}>{formatDate(date)}</time>
          {tags.length > 0 && (
            <>
              <span class="article-meta-sep">|</span>
              {tags.map(tag => <span class="tag">{tag}</span>)}
            </>
          )}
        </div>

        <h1 class="article-title">{title}</h1>

        <div class="article-byline">
          Poker Vlogger &middot; {readTime} min read
        </div>
      </header>

      <hr class="article-divider" />

      <div class="prose-content">
        <Content />
      </div>

      <footer class="article-footer">
        <hr class="article-divider" />

        {tags.length > 0 && (
          <div class="tag-cloud">
            {tags.map(tag => <span class="tag">{tag}</span>)}
          </div>
        )}

        <AppCTA />

        <!-- Related Reading -->
        {relatedVlogs.length > 0 && (
          <section class="related-reading">
            <h3 class="related-heading">Related Reading</h3>
            <div class="related-grid">
              {relatedVlogs.map(rv => <VlogCard vlog={rv} />)}
            </div>
          </section>
        )}

        <nav>
          <a href={import.meta.env.BASE_URL || '/'} class="back-link">
            &larr; Back to Home
          </a>
        </nav>
      </footer>
    </article>
  </div>
</BaseLayout>

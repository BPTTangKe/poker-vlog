---
import BaseLayout from '../layouts/BaseLayout.astro';
import Breadcrumb from '../components/Breadcrumb.astro';

const title = 'About & Poker Tracker App';
const description = 'Learn about the best free poker tracker app. Session tracking, bankroll management, and professional poker strategy from an experienced player.';
---

<BaseLayout
  title="About"
  description={description}
  canonicalURL={new URL(`${import.meta.env.BASE_URL}about`, Astro.site).href}
>
  <div class="main-content">
    <Breadcrumb items={[{ label: 'About' }]} />

    <div class="about-page">
      <h1>About the Vlog</h1>

      <section class="about-section">
        <p>
          I'm a professional Texas Hold'em player and content creator. I started playing poker in
          2018 and navigated the full journey — from a recreational player losing at micro stakes to
          beating NL200 consistently. Every upswing, downswing, and hard lesson is now shared through
          this vlog.
        </p>
        <p>
          My poker philosophy: <strong>process over results</strong>. Make the right decision every
          hand, and the money follows. This vlog covers everything from beginner fundamentals to
          advanced GTO concepts.
        </p>
      </section>

      <section class="about-section">
        <h2>About BPT - Best Poker Tracker</h2>
        <p>
          <strong>BPT</strong> is the ultimate <strong>free poker tracker</strong> built for serious
          players. It combines a <strong>poker session tracker</strong>, <strong>poker bankroll
          tracker</strong>, and <strong>poker logger</strong> into one intuitive app.
        </p>
        <ul>
          <li><strong>Poker Session Tracker</strong> — Log sessions with stakes, location, duration, and results. Track win rates and hourly.</li>
          <li><strong>Poker Bankroll Tracker</strong> — Real-time bankroll monitoring with charts, stop-loss alerts, and ROI analysis.</li>
          <li><strong>Poker Logger</strong> — Record hands with position, action, and outcome. Tag for review, identify leaks.</li>
          <li><strong>Strategy Feed</strong> — Daily strategy articles, tournament recaps, and hand analysis delivered to your phone.</li>
          <li><strong>Offline Access</strong> — Download content and track sessions without an internet connection.</li>
        </ul>
      </section>

      <section class="about-section">
        <h2>Why BPT?</h2>
        <p>
          Most poker tools are either too complex (pro-only) or too shallow (no real improvement).
          <strong>BPT finds the sweet spot</strong> — actionable, practical content for players who
          are serious about moving up in stakes. Whether you're grinding $1/$2 live or battling NL100
          online, this <strong>poker tracker</strong> has what you need.
        </p>
      </section>

      <!-- Download CTA -->
      <div class="about-cta">
        <h3>Ready to Level Up?</h3>
        <p>Download <strong>BPT - Best Poker Tracker</strong> — the best free poker tracker with session logging and bankroll management.</p>
        <div class="about-cta-buttons">
          <a href="https://apps.apple.com/us/app/bpt-best-poker-tracker/id6778269945" class="btn btn-primary" target="_blank" rel="noopener noreferrer">
            <svg width="18" height="18" fill="currentColor" viewBox="0 0 24 24"><path d="M18.71 19.5c-.83 1.24-1.71 2.45-3.05 2.47-1.34.03-1.77-.79-3.29-.79-1.53 0-2 .77-3.27.82-1.31.05-2.3-1.32-3.14-2.53C4.25 17 2.94 12.45 4.7 9.39c.87-1.52 2.43-2.48 4.12-2.51 1.28-.02 2.5.87 3.29.87.78 0 2.26-1.07 3.8-.91.65.03 2.47.26 3.64 1.98-.09.06-2.17 1.28-2.15 3.81.03 3.02 2.65 4.03 2.68 4.04-.03.07-.42 1.44-1.38 2.83M13 3.5c.73-.83 1.94-1.46 2.94-1.5.13 1.17-.34 2.35-1.04 3.19-.69.85-1.83 1.51-2.95 1.42-.15-1.15.41-2.35 1.05-3.11z"/></svg>
            App Store
          </a>
          <a href="https://bpt.lanzn.com/iZfRr3tgy9sf" class="btn btn-outline" target="_blank" rel="noopener noreferrer">
            <svg width="18" height="18" fill="currentColor" viewBox="0 0 24 24"><path d="M6 18c0 .55.45 1 1 1h1v3.5a1.5 1.5 0 003 0V19h2v3.5a1.5 1.5 0 003 0V19h1c.55 0 1-.45 1-1V8H6v10zM3.5 8C2.67 8 2 8.67 2 9.5v7c0 .83.67 1.5 1.5 1.5S5 17.33 5 16.5v-7C5 8.67 4.33 8 3.5 8zm17 0c-.83 0-1.5.67-1.5 1.5v7c0 .83.67 1.5 1.5 1.5s1.5-.67 1.5-1.5v-7c0-.83-.67-1.5-1.5-1.5zm-4.97-5.84l1.3-1.3c.2-.2.2-.51 0-.71-.2-.2-.51-.2-.71 0l-1.48 1.48A5.96 5.96 0 0012 1c-.96 0-1.86.23-2.66.63L7.85.15c-.2-.2-.51-.2-.71 0-.2.2-.2.51 0 .71l1.31 1.31A5.983 5.983 0 006 7h12c0-1.99-.97-3.75-2.47-4.84zM10 5H9V4h1v1zm5 0h-1V4h1v1z"/></svg>
            Android APK
          </a>
        </div>
        <p class="about-cta-hint">Android password: BPTT</p>
      </div>

      <!-- Bottom Cards -->
      <div class="about-bottom-cards">
        <div class="about-bottom-card">
          <span class="feature-icon">&spades;</span>
          <h4>Strategy Analysis</h4>
          <p>Daily deep dives into hand analysis and poker theory</p>
        </div>
        <div class="about-bottom-card">
          <span class="feature-icon">&clubs;</span>
          <h4>Mental Game</h4>
          <p>Tilt control, emotional discipline, and peak performance</p>
        </div>
        <div class="about-bottom-card">
          <span class="feature-icon">&diams;</span>
          <h4>Bankroll Growth</h4>
          <p>Proven bankroll management and strategic stake progression</p>
        </div>
      </div>
    </div>
  </div>
</BaseLayout>

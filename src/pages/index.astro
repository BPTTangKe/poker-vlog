---
import BaseLayout from '../layouts/BaseLayout.astro';
import AppCTA from '../components/AppCTA.astro';
import VlogCard from '../components/VlogCard.astro';
import { getCollection } from 'astro:content';

const allVlogs = await getCollection('vlog');
allVlogs.sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

const pageSize = 6;
const vlogs = allVlogs.slice(0, pageSize);

const siteTitle = 'Texas Hold\'em Vlog | Free Poker Tracker & Strategy';
const description = 'Master Texas Hold\'em with our free poker tracker. Session tracking, bankroll management, and daily strategy vlogs. Download the best poker logger and start winning today.';
---

<BaseLayout
  title={siteTitle}
  description={description}
  canonicalURL={new URL(import.meta.env.BASE_URL || '/', Astro.site).href}
>
  <!-- Hero -->
  <section class="hero">
    <h1>Texas Hold'em Vlog</h1>
    <p class="hero-subtitle">Strategy, hand analysis, and stories from the felt.</p>

    <div class="hero-actions">
      <a href="#vlogs" class="btn btn-primary">Latest Vlogs</a>
      <a href="https://apps.apple.com/us/app/bpt-best-poker-tracker/id6778269945" class="btn btn-outline" target="_blank" rel="noopener noreferrer">Get BPT Tracker</a>
    </div>

    <hr class="hero-divider" />

    <div class="hero-stats">
      <div class="hero-stat">
        <div class="hero-stat-value">{allVlogs.length}+</div>
        <div class="hero-stat-label">Strategy Vlogs</div>
      </div>
      <div class="hero-stat">
        <div class="hero-stat-value" style="color:var(--c-accent)">Free</div>
        <div class="hero-stat-label">Poker Tracker</div>
      </div>
      <div class="hero-stat">
        <div class="hero-stat-value">24/7</div>
        <div class="hero-stat-label">Updates</div>
      </div>
    </div>
  </section>

  <!-- Features Banner -->
  <div class="main-content">
    <section class="features-banner">
      <div class="features-grid">
        <div class="feature-item">
          <span class="feature-icon">&spades;</span>
          <h3>Free Poker Tracker</h3>
          <p>Completely free session tracking with win rates, hourly, and detailed stats — no account required.</p>
        </div>
        <div class="feature-item">
          <span class="feature-icon" style="color:hsl(0,60%,55%)">&hearts;</span>
          <h3>Poker Session Tracker</h3>
          <p>Log every session with stakes, location, duration, and results. Track your progress over time.</p>
        </div>
        <div class="feature-item">
          <span class="feature-icon">&diams;</span>
          <h3>Poker Bankroll Tracker</h3>
          <p>Real-time bankroll monitoring with charts, stop-loss alerts, and ROI analysis at a glance.</p>
        </div>
      </div>
    </section>

    <!-- App CTA -->
    <AppCTA variant="banner" />

    <!-- Vlog List -->
    <section id="vlogs" class="vlog-list">
      <h2 class="section-heading">Latest Vlogs</h2>
      {
        vlogs.map(vlog => <VlogCard vlog={vlog} />)
      }

      {allVlogs.length > pageSize && (
        <div style="text-align:center;margin-top:var(--s8)">
          <a href={`${import.meta.env.BASE_URL}archive`} class="btn btn-outline">
            View All {allVlogs.length} Vlogs &rarr;
          </a>
        </div>
      )}
    </section>

    <!-- Bottom CTA -->
    <section class="cta-banner">
      <div class="cta-banner-inner">
        <div>
          <h3>Power Your Game with BPT</h3>
          <p>Download the best free poker tracker with session logging, bankroll management, and detailed hand analysis.</p>
        </div>
        <div class="cta-banner-buttons">
          <a href="https://apps.apple.com/us/app/bpt-best-poker-tracker/id6778269945" class="btn btn-primary" target="_blank" rel="noopener noreferrer">
            <svg width="18" height="18" fill="currentColor" viewBox="0 0 24 24"><path d="M18.71 19.5c-.83 1.24-1.71 2.45-3.05 2.47-1.34.03-1.77-.79-3.29-.79-1.53 0-2 .77-3.27.82-1.31.05-2.3-1.32-3.14-2.53C4.25 17 2.94 12.45 4.7 9.39c.87-1.52 2.43-2.48 4.12-2.51 1.28-.02 2.5.87 3.29.87.78 0 2.26-1.07 3.8-.91.65.03 2.47.26 3.64 1.98-.09.06-2.17 1.28-2.15 3.81.03 3.02 2.65 4.03 2.68 4.04-.03.07-.42 1.44-1.38 2.83M13 3.5c.73-.83 1.94-1.46 2.94-1.5.13 1.17-.34 2.35-1.04 3.19-.69.85-1.83 1.51-2.95 1.42-.15-1.15.41-2.35 1.05-3.11z"/></svg>
            App Store
          </a>
          <a href="https://bpt.lanzn.com/iZfRr3tgy9sf" class="btn btn-outline" target="_blank" rel="noopener noreferrer">
            <svg width="18" height="18" fill="currentColor" viewBox="0 0 24 24"><path d="M6 18c0 .55.45 1 1 1h1v3.5a1.5 1.5 0 003 0V19h2v3.5a1.5 1.5 0 003 0V19h1c.55 0 1-.45 1-1V8H6v10zM3.5 8C2.67 8 2 8.67 2 9.5v7c0 .83.67 1.5 1.5 1.5S5 17.33 5 16.5v-7C5 8.67 4.33 8 3.5 8zm17 0c-.83 0-1.5.67-1.5 1.5v7c0 .83.67 1.5 1.5 1.5s1.5-.67 1.5-1.5v-7c0-.83-.67-1.5-1.5-1.5zm-4.97-5.84l1.3-1.3c.2-.2.2-.51 0-.71-.2-.2-.51-.2-.71 0l-1.48 1.48A5.96 5.96 0 0012 1c-.96 0-1.86.23-2.66.63L7.85.15c-.2-.2-.51-.2-.71 0-.2.2-.2.51 0 .71l1.31 1.31A5.983 5.983 0 006 7h12c0-1.99-.97-3.75-2.47-4.84zM10 5H9V4h1v1zm5 0h-1V4h1v1z"/></svg>
            Android
          </a>
        </div>
      </div>
    </section>
  </div>
</BaseLayout>

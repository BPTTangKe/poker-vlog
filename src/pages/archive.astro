---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const allVlogs = await getCollection('vlog');
allVlogs.sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

function formatDate(d: Date): string {
  const months = ['Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec'];
  return `${months[d.getMonth()]} ${d.getDate()}, ${d.getFullYear()}`;
}

const byYear: Record<string, typeof allVlogs> = {};
for (const vlog of allVlogs) {
  const year = String(vlog.data.date.getFullYear());
  if (!byYear[year]) byYear[year] = [];
  byYear[year].push(vlog);
}

const description = 'Browse all poker vlog articles — strategy, hand analysis, and tournament recaps.';
---

<BaseLayout
  title="Archive | Poker Vlog"
  description={description}
  canonicalURL={new URL(`${import.meta.env.BASE_URL}archive`, Astro.site).href}
>
  <div class="main-content">
    <header class="archive-header">
      <h1>All Vlogs</h1>
      <p>{allVlogs.length} articles and counting</p>
    </header>

    <div class="timeline">
      {Object.entries(byYear).map(([year, vlogs]) => (
        <div class="timeline-year">
          <h2 class="timeline-year-title">{year}</h2>
          <div class="timeline-entries">
            {vlogs.map(vlog => {
              const slug = vlog.id.replace(/\.md$/, '');
              return (
                <div class="timeline-entry">
                  <time class="timeline-entry-date" datetime={vlog.data.date.toISOString()}>
                    {formatDate(vlog.data.date)}
                  </time>
                  <span class="timeline-entry-title">
                    <a href={`${import.meta.env.BASE_URL}vlog/${slug}`}>{vlog.data.title}</a>
                  </span>
                </div>
              );
            })}
          </div>
        </div>
      ))}
    </div>
  </div>
</BaseLayout>
